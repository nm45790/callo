# 이 파일을 복사해서 .env 로 만든 뒤 값을 채우세요:
#   cp .env.example .env
# (.env 는 git에 올라가지 않습니다 — 실제 비밀값은 .env 에)

# docker-compose.yml 이 읽어가는 DB 계정 정보
POSTGRES_USER=diet
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dietlog

# Next.js(Prisma)가 쓰는 접속 주소 (위 USER/PASSWORD/DB 와 일치시킬 것)
DATABASE_URL="postgresql://diet:changeme@localhost:5432/dietlog?schema=public"
